<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="planetary_terrain">
    <static>true</static>
    <link name="terrain_link">
      <collision name="terrain_collision">
        <geometry>
          <heightmap>
            <uri>meshes/heightmap.png</uri>
            <size>50 50 10</size>
