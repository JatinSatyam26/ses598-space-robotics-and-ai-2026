      </collision>
      <visual name="terrain_visual">
        <geometry>
          <heightmap>
            <uri>meshes/heightmap.png</uri>
            <size>50 50 10</size>
            <pos>0 0 0</pos>
          </heightmap>
        </geometry>
        <material>
          <ambient>0.5 0.4 0.3 1</ambient>
